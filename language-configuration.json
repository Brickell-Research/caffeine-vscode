{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "folding": {
    "indentationRules": {}
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(Assumes|Requires|Provides|Type|\".+\"(\\s+(success_rate|time_slice))?(\\s+extends\\s+\\[[^\\]]*\\])?|_[A-Za-z_][A-Za-z0-9_]*\\s*\\([A-Za-z]+\\)).*:\\s*$",
    "decreaseIndentPattern": "^\\s*\\}"
  }
}
