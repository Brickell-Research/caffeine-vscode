{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Caffeine",
  "scopeName": "source.caffeine",
  "fileTypes": ["caffeine"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#extendable" },
    { "include": "#envelope" },
    { "include": "#keywords" },
    { "include": "#expectation_types" },
    { "include": "#types" },
    { "include": "#strings" },
    { "include": "#durations" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.doc.caffeine",
          "match": "###.*$"
        },
        {
          "name": "comment.line.number-sign.section.caffeine",
          "match": "##.*$"
        },
        {
          "name": "comment.line.number-sign.caffeine",
          "match": "#.*$"
        }
      ]
    },
    "extendable": {
      "patterns": [
        {
          "name": "entity.name.function.extendable.caffeine",
          "match": "(_[a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        },
        {
          "name": "entity.name.variable.extendable.caffeine",
          "match": "_[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "envelope": {
      "patterns": [
        {
          "name": "keyword.control.envelope.caffeine",
          "match": "\\b(Assumes|Guarantees)\\b"
        },
        {
          "name": "keyword.control.clause.caffeine",
          "match": "\\b(over|window|as|measured|by|with|below|on)\\b"
        },
        {
          "name": "keyword.control.external_indicator.caffeine",
          "match": "\\b(from|where|and)\\b"
        },
        {
          "name": "keyword.control.dependency.caffeine",
          "match": "\\b(hard|soft)\\s+dependency\\b"
        },
        {
          "name": "keyword.control.dependency.caffeine",
          "match": "\\bdependency\\b"
        }
      ]
    },
    "expectation_types": {
      "patterns": [
        {
          "name": "support.type.expectation.caffeine",
          "match": "\\b(success_rate|time_slice)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.extends.caffeine",
          "match": "\\bextends\\b"
        },
        {
          "name": "keyword.control.requires.caffeine",
          "match": "\\bRequires\\b"
        },
        {
          "name": "keyword.control.provides.caffeine",
          "match": "\\bProvides\\b"
        },
        {
          "name": "keyword.control.type.caffeine",
          "match": "\\bType\\b"
        },
        {
          "name": "keyword.control.in.caffeine",
          "match": "\\bin\\b"
        },
        {
          "name": "variable.language.refinement.caffeine",
          "match": "\\bx\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.caffeine",
          "match": "\\b(String|Integer|Float|Boolean|Percentage|URL)\\b"
        },
        {
          "name": "support.type.collection.caffeine",
          "match": "\\b(List|Dict)\\b"
        },
        {
          "name": "support.type.modifier.caffeine",
          "match": "\\b(Optional|Defaulted)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.caffeine",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.caffeine",
          "match": "\\\\."
        },
        {
          "comment": "Template variable: $$var$$ or $$header->var$$ or $$header->var:not$$",
          "name": "variable.other.template.caffeine",
          "match": "\\$\\$[a-zA-Z_][a-zA-Z0-9_]*(?:->[-a-zA-Z_][a-zA-Z0-9_.]*)?(?::not)?\\$\\$"
        }
      ]
    },
    "durations": {
      "patterns": [
        {
          "name": "constant.numeric.duration.caffeine",
          "match": "-?\\b[0-9]+(?:\\.[0-9]+)?(?:ms|s|m|h|d)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.caffeine",
          "match": "-?\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.caffeine",
          "match": "-?\\b[0-9]+\\b"
        }
      ]
    },
    "booleans": {
      "name": "constant.language.boolean.caffeine",
      "match": "\\b(true|false)\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.range.caffeine",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.logical.caffeine",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.assignment.caffeine",
          "match": "="
        },
        {
          "name": "constant.numeric.percentage.caffeine",
          "match": "-?\\b[0-9]+\\.?[0-9]*%"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.colon.caffeine",
          "match": ":"
        },
        {
          "name": "punctuation.separator.comma.caffeine",
          "match": ","
        },
        {
          "name": "punctuation.section.braces.begin.caffeine",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.caffeine",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.parens.begin.caffeine",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.caffeine",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.caffeine",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.caffeine",
          "match": "\\]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "support.type.property-name.caffeine",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*:)"
        },
        {
          "name": "variable.other.caffeine",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
